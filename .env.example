# App
MANDATE_ENVIRONMENT=local
MANDATE_DEBUG=true
MANDATE_SECRET_KEY=change-me-in-production
MANDATE_API_PREFIX=/api/v1

# Database
MANDATE_DATABASE_URL=postgresql+asyncpg://mandate:mandate@127.0.0.1:5432/mandate_finder
MANDATE_DATABASE_URL_SYNC=postgresql+psycopg://mandate:mandate@127.0.0.1:5432/mandate_finder

# Propelauth
MANDATE_PROPELAUTH_API_KEY=
MANDATE_PROPELAUTH_AUTH_URL=https://4881448908.propelauthtest.com

# Local/dev token (only active when ENVIRONMENT=local and Propelauth not configured)
MANDATE_DEV_AUTH_TOKEN=mandate-local-dev-token

# CORS
MANDATE_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
